# ══════════════════════════════════════════════════════════════
# BetArena Environment Variables
# Copy to .env at the repo root and fill in real values
# For local dev the API reads from apps/api/.env
# and the frontend reads from apps/web/.env.local
# ══════════════════════════════════════════════════════════════

# ── Server ───────────────────────────────────────────────────
NODE_ENV=development            # development | production
PORT=4000                       # API server port

# ── PostgreSQL ───────────────────────────────────────────────
DB_HOST=127.0.0.1               # Use "postgres" inside Docker
DB_PORT=5432                    # Default Postgres port (mapped to 5433 in dev)
DB_NAME=betarena
DB_USER=betarena
DB_PASSWORD=your_db_password_here

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1            # Use "redis" inside Docker
REDIS_PORT=6379                 # Default Redis port (mapped to 6380 in dev)
REDIS_PASSWORD=                 # Leave blank for local dev; set for production

# ── Railway (auto-injected) ────────────────────────────────
# These are set automatically by Railway plugins.
# Do NOT set them locally — the individual vars above are used instead.
# DATABASE_URL=                  # Set by Railway PostgreSQL plugin
# REDIS_URL=                     # Set by Railway Redis plugin

# ── JWT ──────────────────────────────────────────────────────
# Generate strong random strings for production:
#   openssl rand -base64 64
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# ── Admin Seed ───────────────────────────────────────────────
ADMIN_SEED_PASSWORD=change_this_before_running_seeds

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000   # Comma-separated origins if needed

# ── Sports Data APIs ────────────────────────────────────────
# API-Football (v3.football.api-sports.io) — 100 req/day free
APISPORTS_KEY=

# ESPN hidden API — no key required (free public API)

# TheSportsDB — free tier key is "123" (hardcoded in provider)

# CricketData.org — 100 req/day free
CRICKET_API_KEY=

# OddsPapi (api.oddspapi.io) — 200 req/month free
ODDSPAPI_KEY=

# The Odds API (api.the-odds-api.com) — 500 credits/month free
ODDS_API_KEY=

# ── Frontend (apps/web) ─────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000
